# Vite ENV Configuration
#
# Supabase target is NOT configured here. It comes from committed Vite
# mode files, selected by which command you run:
#   .env.development  -> local Supabase   (npm run dev / dev:local)
#   .env.remote       -> remote Supabase  (npm run dev:remote)
#
# .env.local (gitignored) is only for local secret overrides. Copy this
# file to .env.local and add any secrets your setup needs:
#   cp .env.example .env.local

# Gemini API Key (optional local override)
GEMINI_API_KEY=your_gemini_key_here
