# Edge function env — TEMPLATE (committed; no real secrets).
#
# Do not use this file directly. Instead create the two mode files:
#   supabase/functions/.env.development   (local mode)
#   supabase/functions/.env.remote        (remote mode)
# then switch between them with:
#   npm run functions:env:local
#   npm run functions:env:remote
# The active file is copied to supabase/functions/.env, which the
# Supabase CLI reads when serving edge functions locally.

# Gemini API Key (required for the generate-recommendation function)
GEMINI_API_KEY=your_gemini_key_here

# Firecrawl API Key (required for parse-properties and analyze-properties)
FIRECRAWL_API_KEY=your_firecrawl_key_here

# Firecrawl base URL.
# Local self-hosted container: http://host.docker.internal:3002
# Hosted service:              https://api.firecrawl.dev
FIRECRAWL_URL=https://api.firecrawl.dev
